# Notion API 配置
# 1. 去 https://www.notion.so/my-integrations 创建 Integration
# 2. 复制 "Internal Integration Secret"
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxx

# 3. 打开你的 Notion Database 页面（桌游数据）
# 4. 从 URL 中复制 Database ID
#    例: https://www.notion.so/abc123def456?v=...
#    Database ID 就是 "abc123def456" 那段
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 对局记录 Database
# 5. 在 Notion 中新建一个 Database，命名为"对局记录"
# 6. 从 URL 中复制它的 Database ID
NOTION_SESSIONS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 玩家 Database
# 7. 在 Notion 中新建一个 Database，命名为"玩家"
# 8. 从 URL 中复制它的 Database ID
NOTION_PLAYERS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 管理员密码（可选）
# 用于保护"创建玩家"和"记录对局"等写操作
# 留空 = 允许所有人操作（默认）
# 设值后，网页端写操作需要输入此密码
ADMIN_PASSWORD=
